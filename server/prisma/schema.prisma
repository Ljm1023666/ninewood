generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums

enum CertLevel {
  NONE
  BASIC
  INTERMEDIATE
  ADVANCED
  MASTER
}

enum ServiceType {
  ONLINE
  OFFLINE
}

enum DemandStatus {
  PENDING
  ACTIVE
  FROZEN
  IN_PROGRESS
  COMPLETED
  CLOSED
  WITHDRAWN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ── AI 2.5+ 新增枚举 ──

enum TagStatus {
  IDLE
  BUSY
  HIDDEN
}

enum ApplicantStatusV2 {
  PENDING
  COMMUNICATING
  ACCEPTED
  REJECTED
  TIMED_OUT
  WITHDRAWN
}

enum LifecycleStage {
  ACTIVE
  NO_COVER
  NO_DETAIL
  ARCHIVED
  DELETED
}

enum CircleLevel {
  COUNTY
  CITY
  PROVINCE
  NATIONAL
}

enum PushFrequency {
  HIGH
  NORMAL
  LOW
  OFF
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  WAITING_REVIEW
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum CircleType {
  PRIVATE
  PUBLIC
}

enum CircleStatus {
  ACTIVE
  WARNING
  DEFUNCT
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum DepositStatus {
  PENDING
  REFUNDED
  FORFEITED
}

enum ComplaintStatus {
  PENDING
  UPHELD
  DISMISSED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  SYSTEM
}

enum DemandStage {
  active
  compressed
  completed
}

enum TagCategory {
  service
  demand
  both
}

model User {
  id                 String    @id @default(uuid())
  phone              String    @unique
  nickname           String
  avatarUrl          String?
  coverUrl           String?
  demandCardCoverUrl String?
  cityCode           String?
  certificationLevel CertLevel @default(NONE)
  snatchCredits      Int       @default(3)
  creditScore        Int       @default(60)
  completedOrders    Int       @default(0)
  role               String    @default("USER")
  passwordHash       String?
  bio                String?
  birthday           DateTime?
  pushBlocklist      Json      @default("{\"tags\":[],\"keywords\":[],\"ageRanges\":[]}")
  hasVisitedCompletedList Boolean   @default(false)
  serviceTags            String[]  @default([])
  isBusy                 Boolean   @default(false)
  allowSpecialSearch     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  demands             Demand[]
  applications        DemandApplication[]
  providerOrders      Order[]     @relation("Provider")
  requesterOrders     Order[]     @relation("Requester")
  ownedCircles        Circle[]    @relation("CircleOwner")
  memberships         CircleMember[]
  deposits            Deposit[]
  sentComplaints      Complaint[] @relation("Complainant")
  receivedComplaints  Complaint[] @relation("Respondent")
  sentMessages        Message[]   @relation("Sender")
  receivedMessages    Message[]   @relation("Receiver")
  shorts              Short[]
  following           Follow[]    @relation("Following")
  followers           Follow[]    @relation("Followers")
  favorites           DemandFavorite[]
  certifiedProvider   CertifiedProvider?
  mergeMemberships    ConversationMergeMember[]
  reviewsGiven        Review[]         @relation("Reviewer")
  reviewsReceived     Review[]         @relation("Reviewee")

  // ── AI 2.5 ──
  userTags           UserTag[]
  applicantsV2       DemandApplicantV2[]
  pushPreference     PushPreference?

  @@index([cityCode])
  @@index([certificationLevel])
}

model Demand {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  description      String
  minPrice         Decimal      @db.Decimal(10, 2)
  category         String
  taxonomyLeafId   String?
  serviceType      ServiceType
  cityCode         String?
  regionId         Int?
  region           Region?      @relation(fields: [regionId], references: [id], onDelete: SetNull)
  tagName          String?      // 关联的标签卡包（null=未分类?卡包）
  isCertifiedOnly  Boolean      @default(false)
  completedCoverImage String?   // 死池永久封面（完成时锁定，不可更改）
  colorBar         String?      // 死池色条
  pushConfig       Json?
  stage            DemandStage  @default(active)
  coverImage       String?
  amountEstimate   Decimal?     @db.Decimal(10, 2)
  expireAt         DateTime
  status           DemandStatus @default(PENDING)
  circleId         String?
  circle           Circle?      @relation(fields: [circleId], references: [id], onDelete: SetNull)
  mediaUrls        Json         @default("[]")
  applicantCount   Int          @default(0)
  isExample        Boolean      @default(false)
  isPublic         Boolean      @default(true)
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())

  // ── AI 2.5: 紧急窗口 ──
  visibilityWindow Int          @default(15)
  visibleUntil     DateTime?
  frozenAt         DateTime?
  // ── AI 2.5: 效果导向 ──
  expectedOutcome  String?
  timeLimit        DateTime?
  // ── AI 2.5: 押金 + 接单控制 ──
  deposit          Float        @default(0)
  maxApplicants    Int          @default(10)
  // ── AI 2.5: 标签确认 ──
  tags             String[]     @default([])
  aiTags           String[]     @default([])
  tagsConfirmed    Boolean      @default(false)
  // ── AI 2.5: 位置模糊 ──
  fuzzyLat         Float?
  fuzzyLng         Float?
  // ── AI 2.5: 正式接单 ──
  acceptedProviderId String?
  // ── AI 2.5: 生命周期 ──
  lifecycleStage   LifecycleStage @default(ACTIVE)
  coverDeletedAt   DateTime?
  detailDeletedAt  DateTime?
  fullDeletedAt    DateTime?
  // ── AI 2.5: 公益 ──
  isPublicWelfare  Boolean      @default(false)

  applications     DemandApplication[]
  applicantsV2     DemandApplicantV2[]
  circleDemands    CircleDemand[]
  orders           Order[]
  favoritedBy      DemandFavorite[]
  depositRelations DepositDemand[]
  activeDemand     ActiveDemand?

  @@index([userId])
  @@index([cityCode])
  @@index([status])
  @@index([expireAt])
  @@index([circleId])
  @@index([category])
  @@index([taxonomyLeafId])
  @@index([isExample])
  @@index([regionId, stage])
  @@index([stage, createdAt])
  @@index([status, visibleUntil])
  @@index([frozenAt])
}

model DemandApplication {
  id         String            @id @default(uuid())
  demandId   String
  demand     Demand            @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerPrice Decimal?          @db.Decimal(10, 2)
  message    String?
  isSnatched Boolean           @default(false)
  status     ApplicationStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  @@unique([demandId, userId])
  @@index([userId])
  @@index([demandId])
  @@index([status])
}

model Order {
  id          String      @id @default(uuid())
  demandId    String
  demand      Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  providerId  String
  provider    User        @relation("Provider", fields: [providerId], references: [id])
  requesterId String
  requester   User        @relation("Requester", fields: [requesterId], references: [id])
  agreedPrice Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  paidAt      DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  messages Message[]
  reviews  Review[]

  @@index([demandId])
  @@index([providerId])
  @@index([requesterId])
  @@index([status])
}

model Circle {
  id          String       @id @default(uuid())
  name        String
  type        CircleType
  ownerId     String
  owner       User         @relation("CircleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  cityCode    String?
  inviteCode  String?      @unique
  coverUrl    String?
  memberCount Int          @default(1)
  activeScore Float        @default(0)
  status      CircleStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())

  members CircleMember[]
  demands Demand[]
  circleDemands CircleDemand[]

  @@index([ownerId])
  @@index([cityCode])
  @@index([status])
}

model CircleMember {
  circleId String
  circle   Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  @@id([circleId, userId])
  @@index([circleId])
  @@index([userId])
}

model Deposit {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Decimal         @db.Decimal(10, 2)
  status          DepositStatus   @default(PENDING)
  createdAt       DateTime        @default(now())

  demandRelations DepositDemand[]

  @@index([userId])
  @@index([status])
}

model DepositDemand {
  depositId String
  deposit   Deposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  demandId  String
  demand    Demand  @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@id([depositId, demandId])
}

model Complaint {
  id         String          @id @default(uuid())
  fromUserId String
  fromUser   User            @relation("Complainant", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User            @relation("Respondent", fields: [toUserId], references: [id], onDelete: Cascade)
  demandId   String
  reason     String
  status     ComplaintStatus @default(PENDING)
  result     String?
  createdAt  DateTime        @default(now())

  @@index([fromUserId])
  @@index([toUserId])
  @@index([demandId])
}

model Review {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId  String
  reviewee    User     @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating      Int      // 1-5
  content     String?
  createdAt   DateTime @default(now())

  @@index([reviewerId])
  @@index([revieweeId])
}

model Message {
  id         String      @id @default(uuid())
  fromUserId String
  fromUser   User        @relation("Sender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User        @relation("Receiver", fields: [toUserId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  content    String
  type       MessageType @default(TEXT)
  duration   Int?
  mergeId    String?
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([fromUserId])
  @@index([toUserId])
  @@index([orderId])
  @@index([mergeId])
  @@index([createdAt])
}

model Short {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl    String
  coverUrl    String?
  description String?
  tags        Json     @default("[]")
  likeCount   Int      @default(0)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ConversationMerge {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())

  members ConversationMergeMember[]
}

model ConversationMergeMember {
  mergeId String
  merge   ConversationMerge @relation(fields: [mergeId], references: [id], onDelete: Cascade)
  userId  String
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([mergeId, userId])
  @@index([userId])
}

model DemandFavorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, demandId])
  @@index([userId])
  @@index([demandId])
}

// ── Agent 对话系统 ──

model AgentConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("新对话")
  model     String?
  provider  String?  // minimax | deepseek
  thinkMode Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AgentMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AgentMessage {
  id             String   @id @default(uuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // user | assistant | system | tool
  content        String
  thinking       String?  // 思考过程（DeepSeek V4 thinking/reasoning）
  toolCalls      Json?    // 工具调用记录 [{ name, arguments, result }]
  tokenCount     Int?
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ── 行政区划表 ──

model Region {
  id       Int      @id
  name     String   @db.VarChar(100)
  level    Int      // 1=国家 2=省 3=市 4=区县
  parentId Int      @default(0)
  lat      Float?
  lng      Float?

  demands          Demand[]
  certifiedProviders CertifiedProvider[]

  @@index([parentId])
}

// ── 标签表 ──

model Tag {
  name                String     @id @db.VarChar(50)
  category            TagCategory @default(both)
  totalCompleted      Int        @default(0)
  totalEstimatedAmount Decimal   @default(0) @db.Decimal(12, 2)
  colorHistogram      Json       @default("[]")
}

// ── 认证服务者表 ──

model CertifiedProvider {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedAt     DateTime @default(now())
  tags           String[] @default([])
  regionId       Int?
  region         Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  avgRating      Float    @default(0)
  totalCompleted Int      @default(0)

  @@index([regionId])
}

// ── 活池需求扩展表（时间杠杆） ──

model ActiveDemand {
  demandId           String    @id
  demand             Demand    @relation(fields: [demandId], references: [id], onDelete: Cascade)
  totalExtendedMonths Int      @default(0)
  nextCompressionDate DateTime?
}

// ─── AI 2.5+ 新增模型 ───

// 服务者标签状态
model UserTag {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagName     String    @db.VarChar(50)
  status      TagStatus @default(IDLE)
  regionId    Int?
  certified   Boolean   @default(false)
  autoReceive Boolean   @default(false)
  rating      Float     @default(0)
  orderCount  Int       @default(0)
  metadata    Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, tagName])
  @@index([status, tagName])
  @@index([tagName, certified])
  @@index([status, regionId])
}

// 需求申请记录（两段式接单 + 沟通窗口）
model DemandApplicantV2 {
  id              String           @id @default(uuid())
  demandId        String
  demand          Demand           @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  message         String           // 申请理由

  status          ApplicantStatusV2 @default(PENDING)

  // 沟通窗口
  commStartAt     DateTime?
  commDeadline    DateTime?
  extensionMinutes Int             @default(0)

  createdAt       DateTime         @default(now())

  @@unique([demandId, userId])
  @@index([demandId, status])
  @@index([userId])
}

// 公益资金池
model WelfareFundPool {
  id           String   @id @default(uuid())
  regionId     Int      @unique
  balance      Float    @default(0)
  totalInflow  Float    @default(0)
  totalOutflow Float    @default(0)
  updatedAt    DateTime @updatedAt
}

// 需求圈-需求关联
model CircleDemand {
  id         String   @id @default(uuid())
  circleId   String
  demandId   String
  demand     Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  isExternal Boolean  @default(false)
  isPublic   Boolean  @default(false)
  circle     Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([circleId, demandId])
}

// 推送偏好
model PushPreference {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  excludeKeywords String[]      @default([])
  excludeTags     String[]      @default([])
  excludeRegions  Int[]         @default([])
  receivePushes   Boolean       @default(true)
  pushFrequency   PushFrequency @default(NORMAL)
}

// 标签统计
model TagStats {
  id               String   @id @default(uuid())
  tagName          String   @db.VarChar(50)
  regionId         Int
  totalCards       Int      @default(0)
  totalAmount      Float    @default(0)
  avgAmount        Float    @default(0)
  activeProviders  Int      @default(0)
  activeDemands    Int      @default(0)
  periodStart      DateTime
  periodEnd        DateTime
  updatedAt        DateTime @updatedAt

  @@unique([tagName, regionId, periodStart])
  @@index([tagName, regionId])
}
