generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum MessageType {
  TEXT
  IMAGE
  VOICE
}

enum DemandStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DemandApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CircleType {
  PUBLIC
  PRIVATE
}

enum CircleStatus {
  ACTIVE
  PENDING
  ARCHIVED
}

enum CircleApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CircleDemandStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  FOLLOW
  COMMENT
  APPLICATION
  SYSTEM
  DEMAND_STATUS
  CIRCLE_JOIN
  CIRCLE_APPLICATION
}

// ── Models ─────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  email      String   @unique
  password   String
  avatar     String?
  background String?
  bio        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  demands              Demand[]
  createdCircles       Circle[]            @relation("CreatedCircles")
  memberships          CircleMember[]
  sentMessages         Message[]           @relation("SentMessages")
  receivedMessages     Message[]           @relation("ReceivedMessages")
  circleMessages       CircleMessage[]
  circleDemands        CircleDemand[]
  demandApplications   DemandApplication[]
  demandComments       DemandComment[]
  circleApplications   CircleApplication[]
  notifications        Notification[]
  feedbacks            Feedback[]
  emojis               UserEmoji[]

  // Follow system
  followers  Follow[] @relation("Following")
  following  Follow[] @relation("Follower")
}

// ── Follow ──

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

// ── Demand ──

model Demand {
  id          String       @id @default(cuid())
  title       String
  description String
  region      String
  category    String
  images      String[]
  status      DemandStatus @default(OPEN)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  applications DemandApplication[]
  comments     DemandComment[]
}

// ── Demand Application ──

model DemandApplication {
  id        String                  @id @default(cuid())
  demandId  String
  demand    Demand                  @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId    String
  user      User                    @relation(fields: [userId], references: [id])
  message   String?
  status    DemandApplicationStatus @default(PENDING)
  createdAt DateTime                @default(now())

  @@unique([demandId, userId])
}

// ── Demand Comment ──

model DemandComment {
  id        String   @id @default(cuid())
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

// ── Circle ──

model Circle {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        CircleType   @default(PRIVATE)
  inviteCode  String?      @unique
  region      String?
  avatar      String?
  status      CircleStatus @default(ACTIVE)
  creatorId   String
  creator     User         @relation("CreatedCircles", fields: [creatorId], references: [id])
  createdAt   DateTime     @default(now())

  members      CircleMember[]
  messages     CircleMessage[]
  demands      CircleDemand[]
  applications CircleApplication[]
}

// ── Circle Member ──

model CircleMember {
  circleId String
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  role     String   @default("member") // member, admin
  joinedAt DateTime @default(now())

  @@id([circleId, userId])
}

// ── Circle Message ──

model CircleMessage {
  id        String   @id @default(cuid())
  content   String
  type      MessageType @default(TEXT)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ── Circle Application ──

model CircleApplication {
  id        String                  @id @default(cuid())
  circleId  String
  circle    Circle                  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId    String
  user      User                    @relation(fields: [userId], references: [id])
  message   String?
  status    CircleApplicationStatus @default(PENDING)
  createdAt DateTime                @default(now())

  @@unique([circleId, userId])
}

// ── Circle Demand ──

model CircleDemand {
  id          String            @id @default(cuid())
  circleId    String
  circle      Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title       String
  description String
  images      String[]
  status      CircleDemandStatus @default(OPEN)
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ── Message ──

model Message {
  id          String      @id @default(cuid())
  content     String
  type        MessageType @default(TEXT)
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id])
  isFavorited Boolean     @default(false)
  createdAt   DateTime    @default(now())
  readAt      DateTime?
}

// ── Message Draft ──

model MessageDraft {
  id       String @id @default(cuid())
  userId   String
  peerId   String
  content  String

  @@unique([userId, peerId])
}

// ── Notification ──

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  content   String
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// ── Feedback ──

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  images    String[]
  createdAt DateTime @default(now())
}

// ── User Emoji ──

model UserEmoji {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  url       String
  createdAt DateTime @default(now())
}

// ── Conversation Merge ──

model ConversationMerge {
  id        String   @id @default(cuid())
  userId    String
  title     String
  memberIds String[] // array of userIds merged into one view
  createdAt DateTime @default(now())
}
