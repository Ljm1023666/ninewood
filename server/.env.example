# ──────────────────────────────────────────────────────────────
# Ninewood 环境变量模板
# 复制为 .env 并填入实际值：  cp .env.example .env
# 大模型详细说明见：docs/LLM-CONFIG.md
# ──────────────────────────────────────────────────────────────

# ─── 基础 ───
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,app://.

# ─── 数据库 ───
DATABASE_URL="postgresql://postgres:198514@localhost:5433/nine_db?schema=public"

# ─── Redis（可选，语义分类缓存等）──
REDIS_URL=redis://localhost:6379

# ─── JWT ───
# 生产环境必须设置随机长字符串，否则进程拒绝启动
JWT_SECRET="change-this-to-a-random-secret-in-production"

# ══════════════════════════════════════════════════════════════
# 大模型（LLM）— 平台兜底 Key
# ══════════════════════════════════════════════════════════════
# 说明：
#   - 下方 Key 为「平台托管」兜底，供未配置个人 Key 的用户试用
#   - 平台 Key 受 AI_PLATFORM_* 配额限制，易触顶
#   - 正式使用请让用户在「设置 → 大模型」绑定自己的 Key（BYOK）
#   - 详见 docs/LLM-CONFIG.md

# 默认提供商：minimax | deepseek | qwen
AI_PROVIDER=qwen

# ─── MiniMax（OpenAI 兼容）──
# 控制台：https://platform.minimaxi.com/
AI_BASE_URL=https://api.minimaxi.com/v1
AI_API_KEY=
AI_MODEL=MiniMax-M2.5
AI_THINK_MODEL=MiniMax-M2.5
AI_FAST_MODEL=MiniMax-M2.5

# ─── DeepSeek ───
# 控制台：https://platform.deepseek.com/
DS_BASE_URL=https://api.deepseek.com/v1
DS_API_KEY=
DS_MODEL=deepseek-chat
DS_THINK_MODEL=deepseek-v4-pro
DS_FAST_MODEL=deepseek-v4-flash

# ─── 通义千问 Qwen（阿里云 DashScope 兼容模式）──
# 控制台：https://bailian.console.aliyun.com/ → API-KEY 管理
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3.7-plus
QWEN_THINK_MODEL=qwen3.7-plus
QWEN_FAST_MODEL=qwen3.7-plus

# ─── 平台托管配额（无个人 Key 时生效）──
# 与 server/src/services/agent/quota.ts 默认值对齐，可用环境变量覆盖
AI_PLATFORM_DAILY_LIMIT=150
AI_PLATFORM_HOURLY_LIMIT=50
AI_PLATFORM_SESSION_LIMIT=250

# 设为 true 时：未绑定个人 Key 的用户无法调用大模型（仅 BYOK）
AI_BYOK_REQUIRED=false

# ─── hCaptcha 人机验证 ───
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ─── 腾讯云短信（可选）──
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APPID=
TENCENT_SMS_SIGN=乌鲁木齐往昔科技有限公司
TENCENT_SMS_TEMPLATE=2631789

# ─── 错误追踪（可选）──
# SENTRY_DSN=

# ─── 语义分类器侧车（可选，Python FastAPI，默认 8001）──
# CLASSIFIER_URL=http://127.0.0.1:8001
