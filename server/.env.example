# ──────────────────────────────────
# Ninewood 环境变量模板
# 复制为 .env 并填入实际值
# ──────────────────────────────────

# ─── 基础 ───
NODE_ENV=production
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── 数据库 ───
DATABASE_URL="postgresql://postgres:password@localhost:5432/nine_db?schema=public"

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
# 生产环境必须设置，否则进程拒绝启动
JWT_SECRET="change-this-to-a-random-secret"

# ─── AI 服务（MiniMax / OpenAI 兼容接口）──
AI_BASE_URL=https://api.minimax.chat/v1
AI_API_KEY=your_minimax_api_key
AI_MODEL=MiniMax-M2.7-highspeed
AI_THINK_MODEL=MiniMax-T1-latest
AI_FAST_MODEL=MiniMax-M2.7-highspeed

# ─── hCaptcha 人机验证 ───
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# ─── 腾讯云短信（可选）──
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_SMS_APPID=your_sms_appid
TENCENT_SMS_SIGN=乌鲁木齐往昔科技有限公司
TENCENT_SMS_TEMPLATE=2631789

# ─── 错误追踪（可选）──
# SENTRY_DSN=your_sentry_dsn
