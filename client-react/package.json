    "react-hook-form": "^7.75.0",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.15.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
