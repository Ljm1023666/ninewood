{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Agent",
      "Skill",
      "Task",
      "WebFetch",
      "WebSearch",
      "AskUserQuestion",
      "ToolSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ],
    "defaultMode": "acceptEdits"
  }
}
